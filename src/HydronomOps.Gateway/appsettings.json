{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "HydronomOps.Gateway": "Information"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "VehicleId": "hydronom-main",
    "Source": "gateway",
    "FreshnessThresholdMs": 1500,
    "SnapshotHistoryLimit": 200,
    "EnableDiagnosticsLogs": true
  },
  "RuntimeTcp": {
    "Host": "127.0.0.1",
    "Port": 5055,
    "AutoConnect": true,
    "ReconnectDelayMs": 2000,
    "ReadTimeoutMs": 1000,
    "WriteTimeoutMs": 1000,
    "BufferSize": 8192
  },
  "WebSocket": {
    "Path": "/ws",
    "KeepAliveSeconds": 15,
    "ReceiveBufferSize": 4096
  }
}